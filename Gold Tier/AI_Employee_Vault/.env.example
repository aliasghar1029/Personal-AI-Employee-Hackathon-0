# Gold Tier AI Employee - Environment Configuration
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!

# ===========================================
# Gmail API Configuration
# ===========================================
# Get credentials from: https://console.cloud.google.com/
# Create OAuth 2.0 credentials and download as credentials.json
# Place credentials.json in AI_Employee_Vault/ folder

GMAIL_CLIENT_ID=your_gmail_client_id_here
GMAIL_CLIENT_SECRET=your_gmail_client_secret_here

# Gmail Watcher Settings
GMAIL_CHECK_INTERVAL=120
MAX_EMAILS_PER_HOUR=10

# Email MCP Server Settings
EMAIL_CHECK_INTERVAL=30

# ===========================================
# LinkedIn API Configuration
# ===========================================
# Get credentials from: https://www.linkedin.com/developers/apps
# Create an app and get OAuth 2.0 credentials

LINKEDIN_CLIENT_ID=your_linkedin_client_id_here
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret_here
LINKEDIN_ACCESS_TOKEN=your_access_token_here
# LinkedIn Poster Settings
LINKEDIN_CHECK_INTERVAL=300
LINKEDIN_SESSION_PATH=./linkedin_session

# ===========================================
# WhatsApp Configuration
# ===========================================
# WhatsApp Web session storage path
WHATSAPP_SESSION_PATH=./whatsapp_session

# WhatsApp Watcher Settings
WHATSAPP_CHECK_INTERVAL=60

# ===========================================
# General Settings
# ===========================================

# Path to your AI Employee Vault
VAULT_PATH=E:\Hackathone\Gold Tier\AI_Employee_Vault

# DRY_RUN mode: true = log only, false = actually send emails/posts
# Keep true until you're ready to go live
DRY_RUN=true

# Payment approval threshold (in USD)
PAYMENT_APPROVAL_THRESHOLD=500

# Scheduler Settings
SCHEDULER_CHECK_INTERVAL=120

# ===========================================
# Facebook Configuration (Gold Tier)
# ===========================================
# Method A - Graph API (Recommended)
# Get credentials from: https://developers.facebook.com/
# Create an app and get Page Access Token

FACEBOOK_APP_ID=your_facebook_app_id_here
FACEBOOK_APP_SECRET=your_facebook_app_secret_here
FACEBOOK_PAGE_ID=your_facebook_page_id_here
FACEBOOK_PAGE_ACCESS_TOKEN=your_facebook_page_access_token_here

# Method B - Playwright (Fallback/Alternative)
# No API setup required - uses browser automation
FACEBOOK_EMAIL=stylerow.owner@gmail.com
FACEBOOK_PASSWORD=asghar12345
FACEBOOK_SESSION_PATH=./facebook_session

# Facebook Manager Settings
FACEBOOK_CHECK_INTERVAL=60
FACEBOOK_API_FIRST=true
FACEBOOK_HEADLESS=false

# ===========================================
# Odoo Accounting Configuration (Gold Tier)
# ===========================================
# Start Odoo with: docker-compose up -d
# Access at: http://localhost:8069
# First login: admin / admin
# Create database: ai_employee
# Install Accounting module

ODOO_URL=http://localhost:8069
ODOO_DB=ai_employee
ODOO_USERNAME=admin
ODOO_PASSWORD=admin
ODOO_CHECK_INTERVAL=60

# ===========================================
# Error Recovery Settings (Gold Tier)
# ===========================================
ERROR_RETRY_DELAY=30
ERROR_MAX_RETRIES=5
HEALTH_CHECK_INTERVAL=60
AUTO_RESTART_DELAY=30

# ===========================================
# Twitter/X Configuration (Future Tier)
# ===========================================
# TWITTER_API_KEY=your_api_key
# TWITTER_API_SECRET=your_api_secret
# TWITTER_ACCESS_TOKEN=your_access_token
# TWITTER_ACCESS_TOKEN_SECRET=your_token_secret

# ===========================================
# Instagram Configuration (Future Tier)
# ===========================================
# INSTAGRAM_ACCESS_TOKEN=your_token

# ===========================================
# Logging Configuration
# ===========================================
LOG_LEVEL=INFO
